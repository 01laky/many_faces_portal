# Development Dockerfile for React Vite application.
# docker-compose.dev.yml bind-mounts ./fe_demo to /app and uses a named volume for
# node_modules, so image-layer installs are invisible at runtime. Dependencies must
# be installed when the container starts (into that volume).

FROM node:22-slim

# docker-compose.dev healthcheck uses wget
RUN apt-get update && apt-get install -y --no-install-recommends wget \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN corepack enable && corepack prepare yarn@4.12.0 --activate

EXPOSE 8081

CMD ["sh", "-c", "yarn install && yarn dev --host 0.0.0.0 --port 8081"]
