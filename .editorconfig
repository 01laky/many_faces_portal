# EditorConfig — many_faces_portal (tabs for source and config)
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 2
tab_width = 2

[*.md]
trim_trailing_whitespace = false

[openapi.json]
insert_final_newline = false
