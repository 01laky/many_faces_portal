{
  "name": "many_faces_portal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,scss,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,scss,css}\"",
    "type-check": "tsc --noEmit",
    "validate": "yarn type-check && yarn lint && yarn format:check",
    "check-node": "node scripts/check-node.mjs",
    "favicon:generate": "node ../scripts/generate-brand-favicons.mjs",
    "test": "vitest run",
    "test:security": "vitest run src/**/*.security.test.ts",
    "tests": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cypress run",
    "test:e2e:ci": "cypress run --spec cypress/e2e/app-load.cy.js",
    "test:e2e:api": "cypress run --spec cypress/e2e/oauth-api-chain.cy.js",
    "test:e2e:open": "cypress open",
    "test:e2e:headed": "cypress run --headed",
    "preview": "vite preview",
    "generate:api": "curl -s http://localhost:8000/swagger/v1/swagger.json > openapi.json && openapi --input ./openapi.json --output ./src/api --client axios --useOptions --useUnionTypes",
    "prepare": "husky"
  },
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=22.14.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,scss,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@microsoft/signalr": "^10.0.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.11",
    "axios": "^1.16.1",
    "bootstrap": "^5.3.8",
    "dompurify": "^3.4.5",
    "form-data": "^4.0.5",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.16.0",
    "quill-delta": "^5.1.0",
    "react": "^19.2.6",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.6",
    "react-grid-layout": "^2.2.3",
    "react-hook-form": "^7.76.0",
    "react-i18next": "^17.0.8",
    "react-loading-indicators": "^1.0.1",
    "react-quill-new": "^3.8.3",
    "react-router-dom": "^7.15.1",
    "react-toastify": "^11.1.0",
    "sass": "^1.99.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@popperjs/core": "^2.11.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/jsdom": "^28",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.7",
    "@yarnpkg/pnpify": "^4.1.6",
    "cypress": "^15.15.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "openapi-typescript-codegen": "^0.30.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vitest": "^4.1.7"
  }
}
